<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Text Style -->
    <style name="TextStyle" />

    <!-- Text Styles -->
    <style name="TextStyle.Display">
        <item name="android:textSize">@dimen/text_size_display</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Headline">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Title">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Body">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/gray_600</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/gray_500</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle.Primary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:minHeight">48dp</item>
    </style>
</resources>
